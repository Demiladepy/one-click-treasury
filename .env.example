# Required for RainbowKit wallet connect (Rabby, MetaMask, etc.)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Intents environment: "dev" (Base Sepolia, order-dev.li.fi) or "mainnet"
NEXT_PUBLIC_INTENTS_ENV=dev

# Get a free project ID at https://cloud.walletconnect.com
# No LI.FI API key needed — order server is open with no rate limits
